# Get your token from https://www.dropbox.com/developers/apps
DROPBOX_ACCESS_TOKEN=your_access_token_here

# The folder path in Dropbox (leave empty for root, or use /FolderName)
DROPBOX_FOLDER_PATH=/Portfolio

# Vercel Blob token (from Vercel dashboard → Storage → Blob)
BLOB_READ_WRITE_TOKEN=your_blob_token_here

# Secret for manual sync trigger (/api/sync?init=true&secret=...)
SYNC_SECRET=your_secret_here

# Are.na mirror (optional — leave unset to disable).
# Personal Access Token from an app at https://dev.are.na/oauth/applications
ARENA_ACCESS_TOKEN=your_arena_token_here
# Channel slug, i.e. the last path segment of the board URL
# (are.na/martijn-mertens/typograaf -> typograaf)
ARENA_CHANNEL_SLUG=typograaf
